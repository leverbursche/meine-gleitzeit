<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MeineGleitzeitApp1" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/green</item>
        <item name="colorPrimaryVariant">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">true</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/black</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <!-- Customize your theme here. -->
        <item name="android:textColor">@color/black</item>
        <item name="android:itemBackground">@color/white</item>
        <!-- ActionBar immer grün, auch im Dark Mode -->
        <item name="actionBarStyle">@style/GreenActionBar</item>
        <!-- Cursor-Auswahl auf halbtransparentes Schwarz stellen -->
        <item name="android:textColorHighlight">#90000000</item>
    </style>

    <style name="GreenActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/green</item>
    </style>
</resources>