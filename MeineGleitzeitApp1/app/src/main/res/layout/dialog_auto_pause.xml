<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:requiresFadingEdge="vertical"
    android:fadingEdgeLength="24dp">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="8dp">

    <!-- Beschreibung -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/auto_pause_beschreibung"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="13sp" />

    <!-- Ein/Aus -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/auto_pause_aktiv"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="16sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchAutoPause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Berechnungsmodus -->
    <RadioGroup
        android:id="@+id/radioGroupModus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <RadioButton
            android:id="@+id/radioPauschal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#4CAF50"
            android:text="@string/auto_pause_modus_pauschal"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="36dp"
            android:paddingBottom="8dp"
            android:text="@string/auto_pause_modus_pauschal_info"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp" />

        <RadioButton
            android:id="@+id/radioDifferenziell"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#4CAF50"
            android:text="@string/auto_pause_modus_differenziell"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="36dp"
            android:paddingBottom="4dp"
            android:text="@string/auto_pause_modus_differenziell_info"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp" />
    </RadioGroup>

    <!-- Spaltenköpfe -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/auto_pause_hint_ab"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp" />

        <View
            android:layout_width="32dp"
            android:layout_height="0dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/auto_pause_hint_pause"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Stufe 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editAb0"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@color/input_background"
            android:inputType="number"
            android:maxLength="4"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp"
            android:selectAllOnFocus="true" />

        <TextView
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="→"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="18sp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editPause0"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@color/input_background"
            android:inputType="number"
            android:maxLength="3"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp"
            android:selectAllOnFocus="true" />
    </LinearLayout>

    <!-- Stufe 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editAb1"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@color/input_background"
            android:inputType="number"
            android:maxLength="4"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp"
            android:selectAllOnFocus="true" />

        <TextView
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="→"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="18sp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editPause1"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@color/input_background"
            android:inputType="number"
            android:maxLength="3"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp"
            android:selectAllOnFocus="true" />
    </LinearLayout>

    <!-- Stufe 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editAb2"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@color/input_background"
            android:inputType="number"
            android:maxLength="4"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp"
            android:selectAllOnFocus="true" />

        <TextView
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="→"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="18sp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editPause2"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@color/input_background"
            android:inputType="number"
            android:maxLength="3"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp"
            android:selectAllOnFocus="true" />
    </LinearLayout>

    <!-- Stufe 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editAb3"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@color/input_background"
            android:inputType="number"
            android:maxLength="4"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp"
            android:selectAllOnFocus="true" />

        <TextView
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="→"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="18sp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editPause3"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@color/input_background"
            android:inputType="number"
            android:maxLength="3"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp"
            android:selectAllOnFocus="true" />
    </LinearLayout>

    <!-- Hinweis: additive Stufen -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/auto_pause_stufen_info"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp" />

    <!-- Mindestdauer Zwischenpause -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/auto_pause_min_zwischenpause"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="14sp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editMinZwischenpause"
            android:layout_width="80dp"
            android:layout_height="52dp"
            android:background="@color/input_background"
            android:inputType="number"
            android:maxLength="3"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp"
            android:selectAllOnFocus="true" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/auto_pause_min_zwischenpause_info"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp" />

    <!-- Erklärung Default-Werte -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/auto_pause_default_erklaerung"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp" />

</LinearLayout>

</ScrollView>
